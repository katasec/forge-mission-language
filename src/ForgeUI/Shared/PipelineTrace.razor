@if (Events.Count > 0 && ShowTrace)
{
    <div class="trace-panel">
        @{ int lastAttempt = 0; }
        @foreach (var ev in Events)
        {
            @if (ev.Attempt > lastAttempt && lastAttempt > 0)
            {
                <div class="trace-retry">
                    ↺ Retry @ev.Attempt — @(Events.FirstOrDefault(e => e.Attempt == lastAttempt && e.Envelope.Status == "fail")?.Envelope.Reason ?? "step failed")
                </div>
            }
            lastAttempt = ev.Attempt;

            <div class="trace-row @(ev.Envelope.Status == "fail" ? "trace-fail" : "trace-pass")">
                <span class="trace-expert">@ev.ExpertName</span>
                <span class="trace-text">@Truncate(ev.Envelope.Text, 120)</span>
                <span class="trace-status">@ev.Envelope.Status</span>
            </div>
        }
    </div>
}

@code {
    [Parameter] public List<PipelineTraceEvent> Events  { get; set; } = [];
    [Parameter] public bool                     ShowTrace { get; set; }

    private static string Truncate(string? text, int max) =>
        string.IsNullOrEmpty(text) ? "" :
        text.Length <= max ? text : text[..max] + "…";
}
