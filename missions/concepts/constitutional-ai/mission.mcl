// Constitutional AI — structured critique against explicit principles
// Bai et al., Anthropic 2022 (https://arxiv.org/pdf/2212.08073)
//
// Pattern: Drafter produces an initial response → ConstitutionalCritic evaluates
// it against numbered principles (the "constitution") → Reviser produces a final
// version that addresses every flagged violation.
//
// The ConstitutionalCritic's expert.md body IS the constitution — readable,
// forkable, and changeable without touching any code.
//
// Usage: forge run --mission ConstitutionalAI

let task = "Explain how neural networks learn, for an executive audience with no machine learning background"

mission ConstitutionalAI(task) = {
    Drafter
    -> ConstitutionalCritic
    -> Reviser
}

output(ConstitutionalAI)
