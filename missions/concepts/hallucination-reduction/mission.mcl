// Hallucination Reduction via Symbolic Grounding
// RLSF (2024): https://arxiv.org/pdf/2405.16661
// Marcus & Belle, AAAI 2025: https://www.rivista.ai/wp-content/uploads/2025/11/Belle_Marcus_AAAI-2.pdf
//
// Pattern: LLMDrafter generates a structured report → FactChecker (kind: rule)
// applies deterministic symbolic checks → if the check fails, the specific
// violation is injected as {{feedback}} and the Drafter retries.
//
// The rule expert is the symbolic grounding layer. It does not estimate or
// guess — it checks. The loop is the correction mechanism. Together they
// implement the "push determinism left, LLM judgment right" principle:
// use a guaranteed-correct rule to catch structural failures, use the LLM
// only for what rules cannot do (generation, reasoning, nuance).
//
// Usage: forge run --mission HallucinationReduction

let topic = "the key technical differences between SQL and NoSQL databases, including when to choose each"

mission HallucinationReduction(topic) loop(3) = {
    LLMDrafter
    -> FactChecker
}

output(HallucinationReduction)
