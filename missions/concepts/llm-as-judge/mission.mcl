// LLM-as-Judge — reference-guided quality evaluation
// Zheng et al., 2023 (https://arxiv.org/abs/2306.05685)
//
// Pattern: Drafter produces a response → ReferenceJudge scores it against an
// explicit rubric and a reference answer (both in the Judge's expert.md body).
// The Judge outputs a numeric score, a verdict, and specific reasoning.
//
// This is Zheng et al.'s "reference-guided judging" pattern — the most reliable
// of the three judging formats studied in the MT-Bench paper. The ReferenceJudge's
// expert.md IS the evaluation rubric and reference answer.
//
// Usage: forge run --mission LLMAsJudge

let question = "Explain the concept of gradient descent to a software engineer who understands calculus but has never studied machine learning. Include why it works, what can go wrong, and one concrete example."

mission LLMAsJudge(question) = {
    Drafter
    -> ReferenceJudge
}

output(LLMAsJudge)
