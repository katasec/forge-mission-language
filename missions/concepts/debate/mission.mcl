// Multi-Agent Debate — diverse perspectives converging on a better answer
// Du et al., 2023 (https://arxiv.org/abs/2401.05998)
//
// Pattern: Three experts with distinct epistemic stances analyse the same question
// independently (in parallel), then a Synthesiser reads all three responses and
// produces a convergent answer that incorporates all perspectives.
//
// This replicates Du et al.'s core finding: diverse independent generation
// followed by synthesis produces better reasoning than any single agent alone.
// The paper showed improvement on arithmetic reasoning, truthfulness, and
// translation tasks. Here the same structure is applied to a contested reasoning
// question about LLM capabilities — the paper's own subject domain.
//
// Usage: forge run --mission Debate

let question = "Can large language models truly reason, or are they sophisticated pattern matchers that simulate reasoning without understanding?"

mission Debate(question) = {
    parallel {
        Optimist
        Sceptic
        Pragmatist
    }
    -> Synthesiser
}

output(Debate)
