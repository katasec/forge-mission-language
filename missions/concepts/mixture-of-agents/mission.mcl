// Mixture of Agents — sequential layered accumulation
// Wang et al., 2024 (https://arxiv.org/abs/2406.04692)
//
// Pattern: four experts in sequence. Each expert receives the full accumulated
// context from all prior experts (the entire conversation history). Each stage
// enriches what the next stage reads. This is the MoA accumulation property:
// "LLMs produce better output when given other models' responses as reference."
//
// Wang et al. showed a MoA of medium-sized models surpassed GPT-4 Omni on
// AlpacaEval 2.0, FLASK, and MT-Bench. This mission uses role-specialised
// experts (MCL's extension of the paper) rather than homogeneous agents.
//
// Usage: forge run --mission MixtureOfAgents

let problem = "Design a distributed rate limiter for an API gateway that must handle 100,000 requests per second across 50 global regions, with per-user quotas, burst allowances, and graceful degradation when the rate limiter itself is unavailable"

mission MixtureOfAgents(problem) = {
    Analyst
    -> Strategist
    -> Implementer
    -> Reviewer
}

output(MixtureOfAgents)
